+
+struct b43_wldev;
+
+/*
+ * Load the AC-PHY init tables into the PHY's table memory.
+ *
+ * On HT this is the long sequence of b43_httab_write{,_few,_bulk}()
+ * calls in b43_phy_ht_tables_init() (in tables_phy_ht.c), driven by
+ * a series of huge static u16/u32 arrays.
+ *
+ * For AC the equivalent arrays do not exist in any open driver.
+ */
+void b43_phy_ac_tables_init(struct b43_wldev *dev);
+
+#endif /* B43_TABLES_PHY_AC_H_ */

diff --git a/drivers/net/wireless/broadcom/b43/tables_phy_ac.c b/drivers/net/wireless/broadcom/b43/tables_phy_ac.c
new file mode 100644
--- /dev/null
+++ b/drivers/net/wireless/broadcom/b43/tables_phy_ac.c
@@ -0,0 +1,68 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Broadcom B43 wireless driver
+ * AC-PHY tables — RFC scaffolding
+ *
+ * On a working PHY this file holds the static arrays of u16 / u32
+ * values that are loaded into the PHY's internal table memory at init
+ * time. On HT-PHY (tables_phy_ht.c) there are roughly:
+ *   - per-table (table_id) arrays, each describing one logical chunk
+ *     (e.g. "RX gain table", "TX gain table", "RFSEQ external", "AGC
+ *     init", "channel-independent radio gain", …),
+ *   - a top-level init function that calls
+ *     b43_httab_write_bulk(dev, B43_HTTAB16(table_id, offset), len, arr)
+ *     for each one.
+ *
+ * For AC we don't have any of these arrays. The plan is:
+ *   1. Identify the table writes performed by the wl proprietary driver
+ *      during init (e.g. with kprobes on b43_httab_write* equivalents,
+ *      or by static disassembly of wl.ko's wlc_phytbl_init_acphy()).
+ *   2. Capture (table_id, offset, value) tuples.
+ *   3. Group them into per-table arrays here.
+ *   4. Call them from b43_phy_ac_tables_init() below.
+ *
+ * Until then this file's only purpose is to define an empty function
+ * so that phy_ac.c links.
+ */
+
+#include "b43.h"
+#include "phy_ac.h"
+#include "tables_phy_ac.h"
+
+/*
+ * Sample arrays — keep the shape, leave the contents marked 0xDEAD so
+ * that if anyone accidentally calls b43_httab_write_bulk() with them,
+ * the values on the wire scream "I am a placeholder" rather than zero
+ * (which is plausibly valid hardware state).
+ *
+ * Pick the table_id values to mirror HT once known; for now, just keep
+ * them as named constants.
+ */
+#define B43_AC_TABLE_ID_RXGAIN_PLACEHOLDER	0
+#define B43_AC_TABLE_ID_TXGAIN_PLACEHOLDER	1
+
+static const u16 b43_phy_ac_tab_rxgain_placeholder[] = {
+	[0 ... 7] = 0xDEAD,
+};
+
+static const u16 b43_phy_ac_tab_txgain_placeholder[] = {
+	[0 ... 7] = 0xDEAD,
+};
+
+/*
+ * The init function. b43_httab_write_bulk is HT-specific (it goes
+ * through the HT-PHY's TABLE_ADDR / TABLE_DATAHI / TABLE_DATALO
+ * registers); for AC the layout is BBCFG-adjacent (TABLE_ID, TABLE_OFFSET,
+ * TABLE_DATA1/2/3). A b43_actab_write* helper will need to be added in
+ * tables.c once we know the exact register sequence.
+ *
+ * For the moment do nothing.
+ */
+void b43_phy_ac_tables_init(struct b43_wldev *dev)
+{
+	(void)dev;
+	(void)b43_phy_ac_tab_rxgain_placeholder;
+	(void)b43_phy_ac_tab_txgain_placeholder;
+
+	/* TODO: write tables via a b43_actab_write_bulk() helper. */
+}
