/*
 * Initial bring-up of the 2069 radio.
 *
 * Extracted from wlc_phy_radio2069_pwron_seq @0x45140 in
 * wlDSL-3580_EU.o_save (initial extraction by extract_radio2069_init.py
 * on the 4360 path; body retargeted to the 0x43b3 path).
 *
 * Structure: prologue (6 PHY writes + 2 RMW + udelay + 1 PHY write,
 * chip-agnostic), body (7 radio_set, chip-dispatched — pages
 * 0x096b/0x096c/0x0407 for {0x4360, 0x4352}, else 0x097f/0x0980/0x0807),
 * epilogue (4 PHY writes + udelay + 2 RMW, chip-agnostic). Body
 * below targets 0x43b3; for a 4352/4360 build, branch around the body
 * section. Phy_rev 3/4 prefregs branch and `*pi[28]->[80] & 0x2`
 * board-flag pre-amble are not ported (dead on DSL-3580L). See
 * reverse-output/by-chip/radio2069_init_extracted_diff.md for the
 * per-chip diff.
 */
static void b43_radio_2069_init(struct b43_wldev *dev)
{
	/* --- Prologo: PHY register writes --- */
	b43_phy_write(dev, 0x0415, 0x0000);  /* @0x00045194 */
	b43_phy_write(dev, 0x040e, 0x0000);  /* @0x000451a4 */
	b43_phy_write(dev, 0x040c, 0x2000);  /* @0x000451b4 */
	b43_phy_write(dev, 0x0408, 0x0000);  /* @0x000451c4 */
	b43_phy_write(dev, 0x0417, 0x0000);  /* @0x000451d4 */
	b43_phy_write(dev, 0x0416, 0x000d);  /* @0x000451e4 */

	/* RMW 1+2: blob salva PHY 0x728, azzera bit 0x8080 e setta
	 * PHY 0x720 | 0x180. Traduciamo in mask/set incondizionali
	 * (sicuri: i bit field non si sovrappongono). */
	b43_phy_mask(dev, 0x0728, 0x7e7f);   /* @0x000451f4 */
	b43_phy_set(dev,  0x0720, 0x0180);   /* @0x00045214 */
	b43_phy_write(dev, 0x0408, 0x0007);  /* @0x00045228 */

	/* --- Setup + udelay(100) --- */
	udelay(100);  /* @0x00045234 */
	b43_phy_write(dev, 0x0408, 0x0006);  /* @0x00045244 */

	/* phy_rev 3/4 prefregs branch (blob @0x4524c) is never taken on
	 * BCM4352-family (phy_rev=1). */

	/* --- Body (0x43b3 path: chipid ∉ {0x4360, 0x4352}) --- */
	b43_radio_set(dev, 0x097f, 0x0800);  /* @0x000452a0 */
	b43_radio_set(dev, 0x097f, 0x4000);  /* @0x000452b4 */
	b43_radio_set(dev, 0x0980, 0x0800);  /* @0x000452c8 */
	b43_radio_set(dev, 0x097f, 0x8000);  /* @0x000452dc */
	b43_radio_set(dev, 0x097f, 0x1000);  /* @0x000452f0 */
	b43_radio_set(dev, 0x097f, 0x0004);  /* @0x00045304 */
	b43_radio_set(dev, 0x0807, 0x0002);  /* @0x00045438 */

	/* --- Epilogue (chip-agnostic, fall-through from per-radio-rev loop) --- */
	b43_phy_write(dev, 0x0417, 0x000d);  /* @0x000456a4 */
	b43_phy_write(dev, 0x0408, 0x0002);  /* @0x000456b4 */
	/* RMW 3: restore PHY 0x728 con bit 0x180 settato */
	b43_phy_set(dev, 0x0728, 0x0180);    /* @0x000456c8 */
	udelay(100);                          /* @0x000456d0 */
	b43_phy_write(dev, 0x0417, 0x0004);  /* @0x000456e0 */
	/* RMW 4: clear bit 0x100 di PHY 0x728 */
	b43_phy_mask(dev, 0x0728, ~0x0100);
}

/**************************************************
 * RF sequencing
 **************************************************/

/*
 * Force a single RF sequence.
 *
 * Pattern transcribed from wlc_phy_force_rfseq_acphy (@0x3b958 in the
 * wl blob), NOT from the HT-PHY analogue: the AC sequencer doesn't
 * have a separate RF_SEQ_MODE register, the "mode" is asserted by
 * ORing 0x3 into RFCTL1 (= reg 0x400) and restoring its prior value
 * at exit. The blob also sets bit 0x1 of reg 0x19E ("RF-seq override
 * gate", separate from the table-write gate at bit 0x2) before the
 * trigger and clears it after.
 *
 * @rf_seq is one of B43_PHY_AC_RF_SEQ_TRIG_{RX2TX,RST2RX,...}.
 *
 * Poll budget matches the blob's literally: 0x30D49 = 200009 counter,
 * decremented by 10 each iter, with osl_delay(10) per iter — i.e.
 * 20000 × 10us = 200ms in the blob. With usleep_range(10, 20) the
 * worst case in this driver is ~400ms (the scheduler can pick the
 * upper bound of the range), so the bound is "200–400ms, never less".
 * The fast path (bit clears within the first read, which is the
 * common case) stays at ~10us; using msleep(1) instead would force
 * ~1ms minimum on the fast path, two orders of magnitude worse than
 * the blob. b43_phy_ht_force_rf_sequence uses msleep(1) and is on
 * our list of things that could become consistent later.
 */
static void __maybe_unused
b43_phy_ac_force_rf_sequence(struct b43_wldev *dev, u16 rf_seq)
{
	u16 saved_rfctl1, saved_gate;
	bool timed_out = true;
	unsigned int i;

	saved_rfctl1 = b43_phy_read(dev, B43_PHY_AC_RFCTL1);
	saved_gate = b43_phy_read(dev, B43_PHY_AC_REG_TBL_WRITE_GATE);

	b43_phy_set(dev, B43_PHY_AC_REG_TBL_WRITE_GATE,
		    B43_PHY_AC_RF_SEQ_OVERRIDE_GATE);
	b43_phy_set(dev, B43_PHY_AC_RFCTL1, 0x3);
	b43_phy_set(dev, B43_PHY_AC_RF_SEQ_TRIG, rf_seq);

	for (i = 0; i < 20000; i++) {
		if (!(b43_phy_read(dev, B43_PHY_AC_RF_SEQ_STATUS) & rf_seq)) {
			timed_out = false;
			break;
		}
		usleep_range(10, 20);
	}
	if (timed_out)
		b43err(dev->wl, "Forcing RF sequence timeout\n");

	b43_phy_write(dev, B43_PHY_AC_RFCTL1, saved_rfctl1);
	b43_phy_maskset(dev, B43_PHY_AC_REG_TBL_WRITE_GATE,
			(u16)~B43_PHY_AC_RF_SEQ_OVERRIDE_GATE,
			saved_gate & B43_PHY_AC_RF_SEQ_OVERRIDE_GATE);
}

/*
 * Reset the CCA (Clear Channel Assessment) state machine.
 *
 * Hand-derived from wlc_phy_resetcca_acphy @0x3be40..0x3bf24 in
 * wlDSL-3580_EU.o_save (228 bytes / 57 instructions). Sequence: force
 * PHY clock, set BBCFG bit 0x4000, 1us, clear bit 0x4000, release
 * clock, force_rfseq(RST2RX). The blob's `pi[0xc0] != 2` guard
 * around the trailing force_rfseq is dead code on every chip-id this
 * binary admits (pi[0xc0] is the PCI device ID, never the literal 2).
 *
 * If a caller ever needs the skip-rfseq variant, thread a bool
 * argument; do not reintroduce a chip-id check at offset 0xC0.
 */
static void __maybe_unused
b43_phy_ac_reset_cca(struct b43_wldev *dev)
{
	u16 saved_bbcfg;

	b43_phy_force_clock(dev, true);

	saved_bbcfg = b43_phy_read(dev, B43_PHY_AC_BBCFG);
	b43_phy_write(dev, B43_PHY_AC_BBCFG,
		      saved_bbcfg | B43_PHY_AC_BBCFG_RSTCCA);
	udelay(1);
	b43_phy_write(dev, B43_PHY_AC_BBCFG,
		      saved_bbcfg & ~B43_PHY_AC_BBCFG_RSTCCA);

	b43_phy_force_clock(dev, false);

	b43_phy_ac_force_rf_sequence(dev, B43_PHY_AC_RF_SEQ_RST2RX);
}

/**************************************************
 * Various PHY ops
 **************************************************/

/*
 * NOTE: the PHY-table-write gate helpers (save+set / restore of bit
 * 0x0002 of register B43_PHY_AC_REG_TBL_WRITE_GATE = 0x19E) live in
 * tables_phy_ac.c, file-local — that is currently the only caller.
 * They will be promoted to a shared header (this file or phy_ac.h)
 * once the rfctrl_override_*_acphy helpers land here, since the wl
 * blob wraps every RF-control override in the same save+set sequence.
 * The register #defines remain in phy_ac.h.
 */

/*
 * Update the classifier control register.
 *
 * The classifier picks which preamble types the PHY decodes (CCK, OFDM,
 * "waited"). The bits are already known (CCKEN/OFDMEN/WAITEDEN) and
 * the offset (0x140) is in the original stub.
 *
 * Use this from switch_channel() to disable OFDM on Japanese channel
 * 14, exactly like b43_phy_ht_classifier() does.
 */
static u16 b43_phy_ac_classifier(struct b43_wldev *dev, u16 mask, u16 val)
{
	u16 tmp;
	u16 allowed = B43_PHY_AC_CLASSCTL_CCKEN |
		      B43_PHY_AC_CLASSCTL_OFDMEN |
		      B43_PHY_AC_CLASSCTL_WAITEDEN;

	tmp = b43_phy_read(dev, B43_PHY_AC_CLASSCTL);
	tmp &= allowed;
	tmp &= ~mask;
	tmp |= (val & mask);
	b43_phy_maskset(dev, B43_PHY_AC_CLASSCTL, ~allowed, tmp);

	return tmp;
}

/**************************************************
 * Channel switching ops
 **************************************************/

/*
 * Per-channel PHY register programming.
 *
 * BW1A..BW6 register offsets are in the 2015 stub. The per-channel
 * values come from the channel table (struct
 * b43_phy_ac_channeltab_e_phy populated in radio_2069.c, currently
 * empty — the caller is gated by a NULL check). Channel 14 disables
 * OFDM via the classifier (CLASSCTL register and the OFDMEN/CCKEN/
 * WAITEDEN bits are also from the stub).
 *
 * Pieces deliberately left out for the MVP:
 *   - the HT-style force_clock + RSTCCA + force RST2RX dance after
 *     channel programming (the AC blob has wlc_phy_resetcca_acphy at
 *     0x3be40 with the RSTCCA bit verified — see ROADMAP §7r.3 — but
 *     the surrounding force_clock / force_rfseq wrapping is HT and
 *     unverified for AC; reintroduce only when an AC caller pattern
 *     is recovered);
 *   - 80 MHz / VHT bandwidth handling (the whole point of AC, biggest
 *     piece missing vs HT-PHY);
 *   - 5 GHz / 2 GHz transition register dance;
 *   - spur avoidance (bcma_pmu_spuravoid_pllupdate + TSF_CLK_FRAC).
 */
static void b43_phy_ac_channel_setup(struct b43_wldev *dev,
				     const struct b43_phy_ac_channeltab_e_phy *e,
				     struct ieee80211_channel *new_channel)
{
	if (!e) {
		b43err(dev->wl, "AC-PHY: no channel table entry, skipping setup\n");
		return;
	}

	b43_phy_write(dev, B43_PHY_AC_BW1A, e->bw1);
	b43_phy_write(dev, B43_PHY_AC_BW2,  e->bw2);
	b43_phy_write(dev, B43_PHY_AC_BW3,  e->bw3);
	b43_phy_write(dev, B43_PHY_AC_BW4,  e->bw4);
	b43_phy_write(dev, B43_PHY_AC_BW5,  e->bw5);
	b43_phy_write(dev, B43_PHY_AC_BW6,  e->bw6);

	if (new_channel->hw_value == 14)
		b43_phy_ac_classifier(dev, B43_PHY_AC_CLASSCTL_OFDMEN, 0);
	else
		b43_phy_ac_classifier(dev, B43_PHY_AC_CLASSCTL_OFDMEN,
				      B43_PHY_AC_CLASSCTL_OFDMEN);
}

static int b43_phy_ac_set_channel(struct b43_wldev *dev,
				  struct ieee80211_channel *channel,
				  enum nl80211_channel_type channel_type)
{
	struct b43_phy *phy = &dev->phy;
	const struct b43_phy_ac_channeltab_e_radio2069 *e2069;

	if (phy->radio_ver != 0x2069)
		return -ESRCH;

	e2069 = b43_phy_ac_get_channeltab_e_r2069(dev, channel->center_freq);
	if (!e2069)
		return -ESRCH;

	b43_radio_2069_channel_setup(dev, e2069);
	b43_phy_ac_channel_setup(dev, &e2069->phy_regs, channel);

	return 0;
}

/**************************************************
 * Basic PHY ops

/* ============================================================
 * BLOCK 7 — INSERT IN drivers/net/wireless/broadcom/b43/phy_ac.c
