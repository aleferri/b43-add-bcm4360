/*
 * prepare_structs is called by the b43 core after allocate() and before
 * init(). Just zero the per-PHY struct: the HT-PHY mirror fields that
 * needed seeding (tx_pwr_ctl = true, bb_mult_save = -1) are gone with
 * their consumers (TX power control / TX-sample calibration are
 * post-MVP — see ROADMAP §7r.5 note on est_pwr_lut and txpwrctrl).
 */
static void b43_phy_ac_op_prepare_structs(struct b43_wldev *dev)
{
	struct b43_phy_ac *phy_ac = dev->phy.ac;

	memset(phy_ac, 0, sizeof(*phy_ac));
}

/* ============================================================
 * BLOCK 8 — INSERT IN drivers/net/wireless/broadcom/b43/phy_ac.c
 *
 * AFTER existing line:
 *     }
 * BEFORE existing line:
 *     static void b43_phy_ac_op_maskset(struct b43_wldev *dev, u16 reg, u16 mask,
 * ============================================================ */

/*
 * Mode-bit clears (phase 3 of op_init).
 *
 * Extracted from wlc_phy_init_acphy @0x53298 for chip 0x43b3 by
 * reverse-tools/extract_init_acphy.py. The "generic" dispatch path
 * (chipid ∉ {0x4352, 0x4360}) emits exactly four PHY writes; the
 * BCM4352/BCM4360 path uses page 0x1xxx instead of 0x07xx for the
 * trailing three. See reverse-output/by-chip/{43b3,4352}/
 * init_acphy_extracted.c and reverse-output/by-chip/
 * init_acphy_extracted_diff.md.
 *
 * The two RMW writes that embed chip-id (chip_id | 0x100/0x400 into
 * 0x72a/0x725) are not statically extractable — left at hardware
 * reset default for MVP.
 */
static void b43_phy_ac_mode_init(struct b43_wldev *dev)
{
	b43_phy_write(dev, 0x0410, 0x0077);  /* @0x0005331c */
	b43_phy_write(dev, 0x0728, 0x0080);  /* @0x000534c0 */
	b43_phy_write(dev, 0x0720, 0x0180);  /* @0x000534e8 */
	b43_phy_write(dev, 0x0721, 0x5000);  /* @0x00053538 */
}

/*
 * BPHY compat init (phase 9 of op_init, 2.4 GHz only).
 *
 * Extracted from wlc_phy_init_acphy post-wlc_phy_radar_detect_init
 * (0x536ac–0x5379c) by reverse-tools/extract_init_acphy.py (2026-04-30).
 * These are the 16 writes to PHY registers 0x33a–0x349: CCK filter
 * coefficients / BPHY compatibility path for 2.4 GHz 1 Mbps operation.
 *
 * Pattern: pairs (0x395, 0x395, 0x315, 0x315) repeated 4× — one group
 * per core/path in the blob's 3-core .rodata layout. Values are
 * constant (no chip-ID dispatch). On 0x43b3 only num_cores=2 of these
 * groups are walked at runtime, but writing all four at compile time
 * is benign (the unused pages are silently ignored). Confirmed
 * against disassembly; no SALAME.
 */
static void b43_phy_ac_bphy_init(struct b43_wldev *dev)
{
	b43_phy_write(dev, 0x033a, 0x0395);  /* @0x000536ac */
	b43_phy_write(dev, 0x033b, 0x0395);  /* @0x000536bc */
	b43_phy_write(dev, 0x033e, 0x0395);  /* @0x000536cc */
	b43_phy_write(dev, 0x033f, 0x0395);  /* @0x000536dc */
	b43_phy_write(dev, 0x0342, 0x0395);  /* @0x000536ec */
	b43_phy_write(dev, 0x0343, 0x0395);  /* @0x000536fc */
	b43_phy_write(dev, 0x0346, 0x0395);  /* @0x0005370c */
	b43_phy_write(dev, 0x0347, 0x0395);  /* @0x0005371c */
	b43_phy_write(dev, 0x033c, 0x0315);  /* @0x0005372c */
	b43_phy_write(dev, 0x033d, 0x0315);  /* @0x0005373c */
	b43_phy_write(dev, 0x0340, 0x0315);  /* @0x0005374c */
	b43_phy_write(dev, 0x0341, 0x0315);  /* @0x0005375c */
	b43_phy_write(dev, 0x0344, 0x0315);  /* @0x0005376c */
	b43_phy_write(dev, 0x0345, 0x0315);  /* @0x0005377c */
	b43_phy_write(dev, 0x0348, 0x0315);  /* @0x0005378c */
	b43_phy_write(dev, 0x0349, 0x0315);  /* @0x0005379c */
}

/*
 * AC-PHY init.
 *
 * The phases below are the subset of wlc_phy_init_acphy that we have
 * either extracted from the blob or grounded in the 2015 stub. The
 * rest of the wl init (PA override / RX2TX / RST2RX bracketing, clip
 * detection, "late" PHY-table writes, full TX power control / TSSI
 * calibration) is intentionally not ported — see ROADMAP §7r.1 (PA
 * override structurally not in op_init for AC, verified) and §7r.5
 * (txpwrctrl post-MVP).
 *
 * What runs here, in order:
 *   - BCMA sanity check;
 *   - tables_init: writes the 24 rev-0 PHY init tables (§7r.5);
 *   - mode_init: pre-table-lock register seeding extracted from
 *     wlc_phy_init_acphy via reverse-tools/extract_init_acphy.py;
 *   - rxgain_init: skeleton port of
 *     wlc_phy_rxgainctrl_set_gaintbls_acphy. Scope deliberately
 *     narrow — see rxgain_phy_ac.c file header. Does NOT yet
 *     populate tables 0x44/0x45;
 *   - AFE bring-up: clear the OVER gates so the hardware sequencer
 *     drives the AFE chains (offsets verified — see phy_ac.h);
 *   - mac_phy_clock_set(true): already implemented in b43 core;
 *   - bphy_init on 2.4 GHz: CCK filter coefficients. Dead code on
 *     this board (DSL-3580L wl1 has aa2g=0); kept for general
 *     BCM4352-family boards where 2.4 GHz antennas are wired;
 *   - TXPCTL fix: disable hardware TX power control and pin a
 *     conservative target. The dBm semantic of 200 is undocumented
 *     in the blob (SALAME — verify on bring-up with a spectrum
 *     analyser or 'iw dev wlan0 link' output). recalc_txpower
 *     returns RES_DONE so the core won't call ->adjust_txpower.
 */
static int b43_phy_ac_op_init(struct b43_wldev *dev)
{
	if (dev->dev->bus_type != B43_BUS_BCMA) {
		b43err(dev->wl, "AC-PHY is supported only on BCMA bus!\n");
		return -EOPNOTSUPP;
	}

	b43_phy_ac_tables_init(dev);
	b43_phy_ac_mode_init(dev);
	b43_phy_ac_rxgain_init(dev);

	/*
	 * AFE: clear PHY-side override registers so the hardware sequencer
	 * drives the AFE chains. Belt-and-braces; b43_phy_init() already
	 * calls ->switch_analog(true) before us.
	 */
	b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_A, 0);
	b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_B, 0);

	b43_mac_phy_clock_set(dev, true);

	if (b43_current_band(dev->wl) == NL80211_BAND_2GHZ)
		b43_phy_ac_bphy_init(dev);

	/* TXPCTL fix: disable HW control, pin targ_pwr = 200 (0xC8).
	 * Extracted from wlc_phy_txpwrctrl_pwr_setup_acphy. */
	b43_phy_maskset(dev, 0x0070, ~0xe000, 0x0000);
	b43_phy_maskset(dev, 0x0071, ~0x00ff, 0x00c8);

	return 0;
}

/*
 * software_rfkill: traduzione del path 0x43b3 di
 * wlc_phy_switch_radio_acphy @0x4582c (op count: on=19 off=11).
 *
 * OFF path (@0x00045c6c..0x00045de8): 8 PHY writes su pagina 0x07xx
 * (radio AFE quench) + 3 writes su pagina 0x04xx (baseband mute).
 *
 * ON path (@0x0004588c..0x00045c00): pwron_seq → 17 radio reg ops
 * con due udelay → rccal. La pwron_seq è già portata come
 * b43_radio_2069_init(); rccal richiede un estrattore separato
 * (TODO sotto), non strettamente necessario per il MVP OFDM 6 Mbit.
 */
static void b43_phy_ac_op_software_rfkill(struct b43_wldev *dev, bool blocked)
{
	if (blocked) {
		b43_phy_write(dev, 0x073e, 0x0000);  /* @0x00045c6c */
		b43_phy_write(dev, 0x0739, 0x0000);  /* @0x00045c94 */
		b43_phy_write(dev, 0x073a, 0x0000);  /* @0x00045cbc */
		b43_phy_write(dev, 0x0725, 0x1fff);  /* @0x00045ce4 */
		b43_phy_write(dev, 0x0729, 0x0000);  /* @0x00045d0c */
		b43_phy_write(dev, 0x0721, 0xffff);  /* @0x00045d34 */
		b43_phy_write(dev, 0x0728, 0x0000);  /* @0x00045d5c */
		b43_phy_write(dev, 0x0720, 0x03ff);  /* @0x00045d88 */
		b43_phy_write(dev, 0x0408, 0x0000);  /* @0x00045d98 */
		b43_phy_write(dev, 0x0417, 0x0000);  /* @0x00045da8 */
		b43_phy_write(dev, 0x0416, 0x0001);  /* @0x00045de8 */
		return;
	}

	if (dev->phy.radio_ver != 0x2069) {
		B43_WARN_ON(1);
		return;
	}

	/* @0x0004588c → wlc_phy_radio2069_pwron_seq */
	b43_radio_2069_init(dev);

	b43_radio_set(dev,   0x08f2, 0x0040);   /* @0x000458dc */
	b43_radio_set(dev,   0x08f2, 0x0080);   /* @0x00045908 */
	b43_radio_mask(dev,  0x08f5, ~0x0600);  /* @0x00045934 */
	b43_radio_mask(dev,  0x08f5, ~0x1800);  /* @0x00045960 */
	b43_radio_set(dev,   0x095b, 0x0001);   /* @0x0004598c */
	b43_radio_write(dev, 0x095c, 0x0000);   /* @0x000459bc */
	b43_radio_write(dev, 0x095d, 0x0000);   /* @0x000459e4 */
	b43_radio_write(dev, 0x095e, 0x0000);   /* @0x00045a0c */
	b43_radio_write(dev, 0x095f, 0x0000);   /* @0x00045a34 */
	b43_radio_mask(dev,  0x0810, ~0x0001);  /* @0x00045a64 */
	udelay(1);                              /* @0x00045a70 */
	b43_radio_set(dev,   0x0810, 0x0001);   /* @0x00045aa0 */
	udelay(10);                             /* @0x00045af0 */
	b43_radio_mask(dev,  0x095b, ~0x0001);  /* @0x00045b6c */
	b43_radio_mask(dev,  0x08f2, ~0x0040);  /* @0x00045b98 */
	b43_radio_mask(dev,  0x08f2, ~0x0080);  /* @0x00045bc4 */
	b43_radio_mask(dev,  0x0810, ~0x0001);  /* @0x00045bf0 */

	/* TODO: wlc_phy_radio2069_rccal @0x00045c00 — chip-agnostic,
	 * non ancora estratto. Servirà un extract_radio2069_rccal.py;
	 * fuori critical path per OFDM 6 Mbit. */
}

/*
 * switch_analog: drive the four PHY-side AFE registers on/off.
 *
 * Values from `.rodata + 0x1a060` (on) and `+ 0x1a048` (off), invoked
 * by `wlc_phy_anacore` @0x65ce0 via `phy_reg_write_array`. The HT-PHY
 * addresses (0x725/0x739/0x925/0x939) are the radio-side AFE on AC,
 * not the PHY-side AFE that this op must drive.
 */
static void b43_phy_ac_op_switch_analog(struct b43_wldev *dev, bool on)
{
	if (on) {
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_DATA_A, 0x000d);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_A,  0x0000);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_DATA_B, 0x000d);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_B,  0x0000);
	} else {
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_A,  0x07ff);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_DATA_A, 0x00fd);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_OVR_B,  0x07ff);
		b43_phy_write(dev, B43_PHY_AC_AFE_PHY_DATA_B, 0x00fd);
	}
}

static int b43_phy_ac_op_switch_channel(struct b43_wldev *dev,
					unsigned int new_channel)
{
	struct ieee80211_channel *channel = dev->wl->hw->conf.chandef.chan;
	enum nl80211_channel_type channel_type =
		cfg80211_get_chandef_type(&dev->wl->hw->conf.chandef);

	if (b43_current_band(dev->wl) == NL80211_BAND_2GHZ) {
		/*
		 * MVP target on this board is 5 GHz UNII-1 only. The
		 * DSL-3580L wl1 SROM declares aa2g=0: no 2.4 GHz
		 * antennas wired, and `wl chanspec 2g*` is rejected
		 * empirically. The chip itself (BCM4352-family) can
		 * do 2.4 GHz on a board with antennas, but on this
		 * unit 2.4 GHz coverage is provided by wl0 (BCM6362,
		 * N-PHY, separate driver path). Drop with a one-shot
		 * dmesg note rather than letting the call land in
		 * b43_phy_ac_set_channel() and fail with -ESRCH after
		 * a misleading channel-table miss.
		 */
		b43dbg(dev->wl,
		       "AC-PHY: 2.4 GHz channel %u rejected (aa2g=0 on this board; MVP is 5 GHz UNII-1)\n",
		       new_channel);
		return -EOPNOTSUPP;
	}

	/*
	 * 5 GHz path. The chan_tuning_2069rev_GE16 entries committed in
	 * radio_2069.c cover only UNII-1 (channels 36/40/44/48). UNII-2/
	 * 2e/3 are also out of scope for the MVP — empirically rejected
	 * with `Bad Channel` by the OEM firmware on this hardware
	 * (regulatory or subband5gver=0x4 related; see top-level README
	 * §"Open questions"). Gate at the UNII-1 range here so the user
	 * gets a clear EOPNOTSUPP rather than a chantab miss for any
	 * other 5 GHz channel; widen the range when the corresponding
	 * sub-band is added to b43_chantab_r2069[].
	 */
	if (new_channel < 36 || new_channel > 48) {
		b43dbg(dev->wl,
		       "AC-PHY: 5 GHz channel %u rejected (MVP covers UNII-1 36/40/44/48 only)\n",
		       new_channel);
		return -EOPNOTSUPP;
	}

	return b43_phy_ac_set_channel(dev, channel, channel_type);
}

/**************************************************
 * R/W ops
 **************************************************/

/*
 * Plain PHY register read/write.
 *
 * The 2015 stub only registered ->phy_maskset, which means b43_phy_read
 * and b43_phy_write (called all over the rest of the b43 core) will
 * dereference a NULL ->phy_read/->phy_write. Add them, identical in
 * shape to phy_ht.c.
 *
 * The B43_WARN_ON(reg == 0xFFFF) gate is a defensive backstop for the
 * register #defines that are intentionally commented out in phy_ac.h
 * (currently B43_PHY_AC_TEST and B43_PHY_AC_RF_SEQ_MODE). If a future
 * patch re-introduces them as 0xFFFF placeholders by mistake, or
 * passes a literal 0xFFFF, this catches the access before it lands
 * on a real register at that MMIO offset. Read returns 0 in the
 * mistake path so the caller doesn't propagate undefined data; write
 * is dropped silently after the warning. The b43_phy_read/write
 * macros that wrap these helpers are uniform across the b43 core, so
 * a single check here covers every PHY-side caller.
 */
static u16 b43_phy_ac_op_read(struct b43_wldev *dev, u16 reg)
{
	if (B43_WARN_ON(reg == 0xFFFF))
		return 0;
	b43_write16f(dev, B43_MMIO_PHY_CONTROL, reg);
	return b43_read16(dev, B43_MMIO_PHY_DATA);
}

static void b43_phy_ac_op_write(struct b43_wldev *dev, u16 reg, u16 value)
{
	if (B43_WARN_ON(reg == 0xFFFF))
		return;
	b43_write16f(dev, B43_MMIO_PHY_CONTROL, reg);
	b43_write16(dev, B43_MMIO_PHY_DATA, value);
}

