/*
 * PHY-table-write gate.  Register 0x19E carries two independent
 * single-bit gates that bracket privileged PHY operations:
 *
 *   bit 0x0002 — table-write gate, asserted across PHY-table writes
 *                (verified in wlc_phy_init_acphy and the
 *                wlc_phy_rfctrl_override_*_acphy family, ~30 strictly
 *                paired triplets).
 *   bit 0x0001 — RF-sequence override gate, asserted across forced
 *                RF sequences (verified in wlc_phy_force_rfseq_acphy
 *                @0x3b958, see phy_ac.c::b43_phy_ac_force_rf_sequence).
 *
 * The two are independent: callers may hold either, both, or neither.
 * The "TBL_WRITE_GATE" register name is kept for backward continuity
 * with the helpers that already exist; a future cleanup might rename
 * it to B43_PHY_AC_REG_GATES once both bits are exercised.
 */
#define B43_PHY_AC_REG_TBL_WRITE_GATE		0x19E
#define  B43_PHY_AC_TBL_WRITE_GATE_LOCK		0x0002
#define  B43_PHY_AC_RF_SEQ_OVERRIDE_GATE	0x0001

/*
 * Per-device PHY state.
 *
 * Currently empty for the AC scaffolding: no field on struct b43_phy_ac
 * is actually read by any code in this patch set. The HT-PHY mirror
 * fields (rf_ctl_int_save / tx_pwr_ctl / tx_pwr_idx / bb_mult_save /
 * idle_tssi) belong to PA-override and TX-power-control paths that are
 * intentionally not implemented here — see ROADMAP §7r.1 (pa_override
 * structurally not in op_init for AC) and the post-MVP txpwrctrl note
 * in §7r.5. Reintroduce only when a real caller lands.
 */

