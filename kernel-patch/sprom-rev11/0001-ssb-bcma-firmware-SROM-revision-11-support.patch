+static void bcm47xx_fill_sprom_path_r11(struct ssb_sprom *sprom,
+					const char *prefix, bool fallback)
+{
+	char postfix[2];
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(sprom->core_pwr_info); i++) {
+		struct ssb_sprom_core_pwr_info *pwr_info;
+
+		pwr_info = &sprom->core_pwr_info[i];
+
+		snprintf(postfix, sizeof(postfix), "%i", i);
+
+		/* Per-chain max power and PA polynomial coefficients.
+		 * SROM rev 11 packs maxp5ga (4 bands), pa2ga (3 coeffs) and
+		 * pa5ga (4 bands × 3 coeffs = 12) as comma-separated lists
+		 * under a single NVRAM key, e.g. "pa5ga0=0xff4d,0x1690,...".
+		 */
+		nvram_read_u8(prefix, postfix, "maxp2ga",
+			      &pwr_info->maxp2ga, 0, fallback);
+		nvram_read_u8_array(prefix, postfix, "maxp5ga",
+				    pwr_info->maxp5ga,
+				    ARRAY_SIZE(pwr_info->maxp5ga), fallback);
+		nvram_read_u16_array(prefix, postfix, "pa2ga",
+				     pwr_info->pa2ga,
+				     ARRAY_SIZE(pwr_info->pa2ga), fallback);
+		nvram_read_u16_array(prefix, postfix, "pa5ga",
+				     pwr_info->pa5ga,
+				     ARRAY_SIZE(pwr_info->pa5ga), fallback);
+
+		/* Per-chain rx gain triplets, one set per band.
+		 * NVRAM keys follow the form rxgains<band><field>a<chain>,
+		 * e.g. "rxgains5gmtrisoa0". Bands: "2g", "5g" (UNII-1 alias),
+		 * "5gm" (UNII-2), "5gh" (UNII-3). Fields: "elnagain", "triso",
+		 * "trelnabyp".
+		 */
+		nvram_read_u8(prefix, postfix, "rxgains2gelnagaina",
+			      &sprom->rxgains_2g.elnagain[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains2gtrisoa",
+			      &sprom->rxgains_2g.triso[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains2gtrelnabypa",
+			      &sprom->rxgains_2g.trelnabyp[i], 0, fallback);
+
+		nvram_read_u8(prefix, postfix, "rxgains5gelnagaina",
+			      &sprom->rxgains_5gl.elnagain[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5gtrisoa",
+			      &sprom->rxgains_5gl.triso[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5gtrelnabypa",
+			      &sprom->rxgains_5gl.trelnabyp[i], 0, fallback);
+
+		nvram_read_u8(prefix, postfix, "rxgains5gmelnagaina",
+			      &sprom->rxgains_5gm.elnagain[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5gmtrisoa",
+			      &sprom->rxgains_5gm.triso[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5gmtrelnabypa",
+			      &sprom->rxgains_5gm.trelnabyp[i], 0, fallback);
+
+		nvram_read_u8(prefix, postfix, "rxgains5ghelnagaina",
+			      &sprom->rxgains_5gh.elnagain[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5ghtrisoa",
+			      &sprom->rxgains_5gh.triso[i], 0, fallback);
+		nvram_read_u8(prefix, postfix, "rxgains5ghtrelnabypa",
+			      &sprom->rxgains_5gh.trelnabyp[i], 0, fallback);
+	}
+}
